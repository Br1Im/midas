DATABASE_URL=postgresql://user:password@localhost:5432/midas
REDIS_URL=redis://localhost:6379/0

# API Keys
OPENAI_API_KEY=sk-...
HUNTER_API_KEY=...

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
